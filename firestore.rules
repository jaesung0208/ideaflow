rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomId} {
      allow read, write: if request.auth != null;
    }
    match /rooms/{roomId}/notes/{noteId} {
      allow read, write: if request.auth != null;
    }
    match /rooms/{roomId}/cursors/{cursorId} {
      allow read, write: if request.auth != null;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
